<Window x:Class="SteelDesignerEngineer.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Steel Designer Engineer - Portal" 
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Navigation Bar -->
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="School" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Steel Designer Engineer" 
                               VerticalAlignment="Center" 
                               FontSize="20" 
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="40,0,0,0">
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="index.html"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Home" Margin="0,0,8,0"/>
                            <TextBlock Text="Main"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="login.html"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Login" Margin="0,0,8,0"/>
                            <TextBlock Text="Login"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="profile.html"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Account" Margin="0,0,8,0"/>
                            <TextBlock Text="Profile"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Browser Controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Command="{Binding GoBackCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="8,0"
                            ToolTip="Back">
                        <materialDesign:PackIcon Kind="ArrowLeft"/>
                    </Button>

                    <Button Command="{Binding GoForwardCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="8,0"
                            ToolTip="Forward">
                        <materialDesign:PackIcon Kind="ArrowRight"/>
                    </Button>

                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="8,0"
                            ToolTip="Refresh">
                        <materialDesign:PackIcon Kind="Refresh"/>
                    </Button>

                    <Separator Style="{StaticResource MaterialDesignDarkSeparator}" Margin="8,0"/>

                    <Button Command="{Binding OpenInExternalBrowserCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="8,0"
                            ToolTip="Open in browser">
                        <materialDesign:PackIcon Kind="OpenInNew"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- WebView2 Browser -->
        <Border Grid.Row="1" 
                BorderBrush="{DynamicResource MaterialDesignDivider}" 
                BorderThickness="0">
            <wpf:WebView2 x:Name="WebViewBrowser"/>
        </Border>

        <!-- Status Bar -->
        <materialDesign:ColorZone Grid.Row="2" Mode="PrimaryLight" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="{Binding StatusIcon}" 
                                             VerticalAlignment="Center" 
                                             Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               VerticalAlignment="Center"
                               FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="1" 
                           Text="{Binding CurrentUrl}" 
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontStyle="Italic"
                           FontSize="11"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Server: " 
                               VerticalAlignment="Center"
                               FontSize="11"/>
                    <Ellipse Width="8" Height="8" 
                             Fill="{Binding ServerStatusColor}"
                             VerticalAlignment="Center"
                             Margin="4,0,8,0"/>
                    <TextBlock Text="{Binding ServerUrl}" 
                               VerticalAlignment="Center"
                               FontSize="11"/>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3" 
              Background="#80000000" 
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Value="0"
                             IsIndeterminate="True"
                             Width="80"
                             Height="80"/>
                <TextBlock Text="{Binding LoadingMessage}" 
                           Foreground="White"
                           FontSize="14"
                           Margin="0,16,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
