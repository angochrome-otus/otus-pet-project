# Qdrant environment variables
# Replace placeholders with secure values in production.
# API key is now random and different from basic auth password.
QDRANT_API_KEY=5cf1e7b6d3a94c5fb0f6e1a3f7c2b9d4e8a1c3f5a6b7d8e9f0a1b2c3d4e5f6
QDRANT_BASIC_AUTH_USER=admin
QDRANT_BASIC_AUTH_PASSWORD=xxx711717XXX
# bcrypt hash of the basic auth password; generate with: htpasswd -nbB "$QDRANT_BASIC_AUTH_USER" "$QDRANT_BASIC_AUTH_PASSWORD" | cut -d: -f2
QDRANT_BASIC_AUTH_PASSWORD_BCRYPT=$2b$12$rw2dLPArBW9ygFpHtUW2/OC8iDybGzoQMxgXPaM3LldZjjkfqKGty
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
# Storage tuning
QDRANT_WAL_CAPACITY_MB=64
QDRANT_INDEXING_THRESHOLD=20000
QDRANT_FLUSH_INTERVAL_SEC=5
