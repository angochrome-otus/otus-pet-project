{
  "categories": [
    {
      "title": "## ?? Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "## ?? Bug Fixes",
      "labels": ["bug", "fix"]
    },
    {
      "title": "## ?? Documentation",
      "labels": ["documentation", "docs"]
    },
    {
      "title": "## ?? Maintenance",
      "labels": ["maintenance", "chore", "refactor"]
    },
    {
      "title": "## ?? Security",
      "labels": ["security"]
    },
    {
      "title": "## ? Performance",
      "labels": ["performance"]
    },
    {
      "title": "## ?? Tests",
      "labels": ["test", "tests"]
    },
    {
      "title": "## ?? Dependencies",
      "labels": ["dependencies"]
    },
    {
      "title": "## ??? Infrastructure",
      "labels": ["infrastructure", "ci", "cd"]
    }
  ],
  "ignore_labels": [
    "ignore",
    "wontfix",
    "duplicate",
    "invalid"
  ],
  "sort": {
    "order": "ASC",
    "on_property": "mergedAt"
  },
  "template": "${{CHANGELOG}}",
  "pr_template": "- ${{TITLE}} (#${{NUMBER}})",
  "empty_template": "- No changes",
  "label_extractor": [
    {
      "pattern": "^(feat|feature)(\\(.+\\))?:",
      "target": "feature"
    },
    {
      "pattern": "^(fix|bug)(\\(.+\\))?:",
      "target": "bug"
    },
    {
      "pattern": "^docs(\\(.+\\))?:",
      "target": "documentation"
    },
    {
      "pattern": "^(refactor|chore)(\\(.+\\))?:",
      "target": "maintenance"
    },
    {
      "pattern": "^perf(\\(.+\\))?:",
      "target": "performance"
    },
    {
      "pattern": "^test(\\(.+\\))?:",
      "target": "test"
    },
    {
      "pattern": "^(ci|cd)(\\(.+\\))?:",
      "target": "infrastructure"
    }
  ],
  "duplicate_filter": {
    "pattern": "\\[DUPLICATE\\]",
    "on_property": "title",
    "method": "match"
  },
  "transformers": [
    {
      "pattern": "[\\-\\*] (\\[(...|TEST|CI|SKIP)\\])(.+?)\n(.+?[\\-\\*] )(.+)",
      "target": "$4$5"
    }
  ],
  "max_tags_to_fetch": 200,
  "max_pull_requests": 200,
  "max_back_track_time_days": 365,
  "exclude_merge_branches": [],
  "tag_resolver": {
    "method": "semver"
  }
}
