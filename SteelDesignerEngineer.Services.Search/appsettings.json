{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "RabbitMQ.Client": "Warning"
    }
  },
  "ConnectionStrings": {
    "RabbitMQ": "amqp://admin:CHANGE_ME@localhost:5672"
  },
  "Qdrant": {
    "BaseUrl": "https://qdrant.steel-designer-engineer.ru",
    "TimeoutSeconds": 30,
    "MaxRetryAttempts": 3,
    "RetryDelayMs": 1000,
    "DefaultCollectionName": "MyCollection",
    "DefaultVectorSize": 768,
    "DefaultDistanceType": "Cosine"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "mxbai-embed-large",
    "TimeoutSeconds": 60
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "DefaultExpiration": 3600,
    "KeyPrefix": "qdrant:embeddings:"
  }
}
