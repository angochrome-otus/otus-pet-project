# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env file to git!

# ============================================
# Docker Registry
# ============================================
GITHUB_REPOSITORY_OWNER=angochrome-otus
DOCKER_IMAGE_NAME=steel-designer-engineer

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_CONNECTION_STRING=mongodb://admin:admin123@mongodb:27017
MONGODB_DATABASE=SteelDesignerDb
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=admin123

# ============================================
# Redis Configuration
# ============================================
REDIS_CONNECTION_STRING=redis:6379,password=redis123
REDIS_INSTANCE_NAME=SteelDesigner:
REDIS_PASSWORD=redis123

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ============================================
# OAuth Configuration
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# Application Settings
# ============================================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80

# ============================================
# Deployment Settings
# ============================================
# For staging
STAGING_HOST=staging.steel-designer-engineer.com
STAGING_USER=deploy
STAGING_PORT=22

# For production
PROD_HOST=steel-designer-engineer.com
PROD_USER=deploy
PROD_PORT=22
