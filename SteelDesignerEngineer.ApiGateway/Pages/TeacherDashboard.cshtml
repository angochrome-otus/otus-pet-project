@page "/teacher-dashboard"
@model SteelDesignerEngineer.ApiGateway.Pages.TeacherDashboardModel
@{
    ViewData["Title"] = "Панель преподавателя";
}

@section Head {
    <style>
        :root{
            --warning: #ffc107;
            --danger: #dc3545;
            --info: #17a2b8;
        }
        
        .dashboard{display:flex; min-height:100vh;}
        
        .sidebar{width:280px; background:rgba(255,255,255,0.95); padding:24px; box-shadow:2px 0 10px rgba(0,0,0,0.1);}
        .sidebar-header{text-align:center; margin-bottom:30px; padding-bottom:20px; border-bottom:2px solid #e0e0e0;}
        .avatar{width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg, var(--warning), #ff6b6b); display:inline-flex; align-items:center; justify-content:center; font-size:36px; margin-bottom:12px; color:white;}
        .user-name{font-size:18px; font-weight:700; margin-bottom:4px;}
        .user-email{font-size:14px; color:var(--muted);}
        .user-role{display:inline-block; padding:4px 8px; border-radius:4px; font-size:12px; font-weight:600; margin-top:8px; background:#fff3cd; color:#856404;}
        
        .menu{list-style:none;}
        .menu li{margin-bottom:8px;}
        .menu a, .menu button{width:100%; display:flex; align-items:center; gap:12px; padding:12px 16px; border-radius:10px; text-decoration:none; border:none; background:transparent; color:#333; transition:all 0.3s; font-weight:500; cursor:pointer; text-align:left; font-family:inherit; font-size:inherit;}
        .menu a:hover, .menu button:hover, .menu a.active{background:linear-gradient(135deg, var(--warning), #ff6b6b); color:white;}
        .menu-icon{font-size:20px;}
        
        .main-content{flex:1; padding:30px;}
        .container{max-width:1200px; margin:0 auto;}
        
        .header{display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; color:white;}
        .header h1{font-size:32px;}
        .btn{padding:10px 20px; border:none; border-radius:8px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-block; transition:all 0.3s;}
        .btn-logout{background:rgba(255,255,255,0.2); color:white; border:2px solid rgba(255,255,255,0.3);}
        
        .alert{padding:12px; border-radius:8px; margin-bottom:20px;}
        .alert-danger{background:#f8d7da; color:#721c24; border:1px solid #f5c6cb;}
        
        .stats-grid{display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:20px; margin-bottom:30px;}
        .stat-card{background:white; border-radius:16px; padding:24px; box-shadow:0 4px 15px rgba(0,0,0,0.1);}
        .stat-icon{width:50px; height:50px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:24px; margin-bottom:12px;}
        .stat-icon.success{background:#d4edda; color:#155724;}
        .stat-icon.warning{background:#fff3cd; color:#856404;}
        .stat-icon.info{background:#d1ecf1; color:#0c5460;}
        .stat-icon.primary{background:#cfe2ff; color:#084298;}
        .stat-value{font-size:28px; font-weight:700; margin-bottom:4px;}
        .stat-label{color:var(--muted); font-size:14px;}
        
        .card{background:white; border-radius:16px; padding:28px; box-shadow:0 4px 15px rgba(0,0,0,0.1); margin-bottom:20px;}
        .card-header{display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; padding-bottom:16px; border-bottom:2px solid #f0f0f0;}
        .card-header h3{font-size:20px; color:#333;}
        
        .course-list{list-style:none;}
        .course-item{display:flex; align-items:center; gap:16px; padding:16px; margin-bottom:12px; border-radius:10px; border:2px solid #e0e0e0;}
        .course-icon{width:50px; height:50px; border-radius:10px; background:linear-gradient(135deg, var(--warning), #ff6b6b); display:flex; align-items:center; justify-content:center; font-size:24px; color:white;}
        .course-details{flex:1;}
        .course-title{font-weight:600; margin-bottom:4px;}
        .course-meta{font-size:14px; color:var(--muted);}
        
        @@media (max-width:768px){
            .dashboard{flex-direction:column;}
            .sidebar{width:100%;}
            .stats-grid{grid-template-columns:1fr;}
        }
    </style>
}

<div class="dashboard">
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="avatar">@Model.AvatarLetter</div>
            <div class="user-name">@Model.FullName</div>
            <div class="user-email">@Model.Email</div>
            <span class="user-role">Преподаватель</span>
        </div>
        
        <ul class="menu">
            <li><a href="/teacher-dashboard" class="active"><span class="menu-icon">📊</span> Панель</a></li>
            <li><a href="#courses"><span class="menu-icon">📚</span> Мои курсы</a></li>
            <li><a href="#students"><span class="menu-icon">👥</span> Студенты</a></li>
            <li><a href="#create"><span class="menu-icon">➕</span> Создать курс</a></li>
            <li><a href="/"><span class="menu-icon">🏠</span> Главная</a></li>
            <li>
                <form method="post" asp-page-handler="Logout">
                    <button type="submit"><span class="menu-icon">🚪</span> Выйти</button>
                </form>
            </li>
        </ul>
    </aside>
    
    <main class="main-content">
        <div class="container">
            <div class="header">
                <h1>Панель преподавателя</h1>
                <form method="post" asp-page-handler="Logout">
                    <button class="btn btn-logout" type="submit">Выйти</button>
                </form>
            </div>
            
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon warning">📚</div>
                    <div class="stat-value">@Model.TeachingCoursesCount</div>
                    <div class="stat-label">Преподаваемые курсы</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon info">👥</div>
                    <div class="stat-value">@Model.TotalStudents</div>
                    <div class="stat-label">Всего студентов</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon success">⭐</div>
                    <div class="stat-value">@Model.AverageRating</div>
                    <div class="stat-label">Средний рейтинг</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon primary">📅</div>
                    <div class="stat-value">@Model.TeachingSince</div>
                    <div class="stat-label">Преподаватель с</div>
                </div>
            </div>
            
            <div class="card" id="courses">
                <div class="card-header">
                    <h3>Мои курсы</h3>
                    <a href="#create" class="btn" style="background:var(--warning);color:white;padding:8px 16px;font-size:14px;">Создать курс</a>
                </div>
                
                @if (Model.TeachingCoursesCount == 0)
                {
                    <div style="text-align:center;color:var(--muted);padding:40px;">Пока нет курсов. Создайте свой первый курс!</div>
                }
                else
                {
                    <ul class="course-list">
                        @foreach (var course in Model.CourseItems)
                        {
                            <li class="course-item">
                                <div class="course-icon">📚</div>
                                <div class="course-details">
                                    <div class="course-title">@course.Title</div>
                                    <div class="course-meta">@course.Meta</div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
            
            <div class="card">
                <div class="card-header">
                    <h3>Информация о преподавателе</h3>
                </div>
                <p><strong>ID пользователя:</strong> @Model.UserId</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Имя:</strong> @Model.FirstName</p>
                <p><strong>Фамилия:</strong> @Model.LastName</p>
                <p><strong>Специализация:</strong> @Model.Specialization</p>
                <p><strong>Ученое звание:</strong> @Model.AcademicTitle</p>
                <p><strong>Биография:</strong> @Model.Bio</p>
            </div>
        </div>
    </main>
</div>
