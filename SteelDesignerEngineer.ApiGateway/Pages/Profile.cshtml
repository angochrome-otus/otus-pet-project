@page "/profile"
@model SteelDesignerEngineer.ApiGateway.Pages.ProfileModel
@{
    ViewData["Title"] = "Профиль";
}

@section Head {
    <style>
        .dashboard{display:flex; min-height:100vh;}
        
        .sidebar{width:280px; background:rgba(255,255,255,0.95); padding:24px; box-shadow:2px 0 10px rgba(0,0,0,0.1);}
        .sidebar-header{text-align:center; margin-bottom:30px; padding-bottom:20px; border-bottom:2px solid #e0e0e0;}
        .avatar{width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg, var(--primary-1), var(--primary-2)); display:inline-flex; align-items:center; justify-content:center; font-size:36px; margin-bottom:12px;}
        .user-name{font-size:18px; font-weight:700; margin-bottom:4px;}
        .user-email{font-size:14px; color:var(--muted);}
        .user-role{display:inline-block; padding:4px 8px; border-radius:4px; font-size:12px; font-weight:600; margin-top:8px;}
        .role-student{background:#d4edda; color:#155724;}
        .role-teacher{background:#fff3cd; color:#856404;}
        .role-admin{background:#f8d7da; color:#721c24;}
        
        .menu{list-style:none;}
        .menu li{margin-bottom:8px;}
        .menu a, .menu button{width:100%; display:flex; align-items:center; gap:12px; padding:12px 16px; border-radius:10px; text-decoration:none; border:none; background:transparent; color:#333; transition:all 0.3s; font-weight:500; cursor:pointer; text-align:left; font-family:inherit; font-size:inherit;}
        .menu a:hover, .menu button:hover, .menu a.active{background:linear-gradient(135deg, var(--primary-1), var(--primary-2)); color:white;}
        .menu-icon{font-size:20px;}
        
        .main-content{flex:1; padding:30px;}
        .container{max-width:1200px; margin:0 auto;}
        
        .header{display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; color:white;}
        .header h1{font-size:32px;}
        .btn{padding:10px 20px; border:none; border-radius:8px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-block; transition:all 0.3s;}
        .btn-logout{background:rgba(255,255,255,0.2); color:white; border:2px solid rgba(255,255,255,0.3);}
        .btn-logout:hover{background:rgba(255,255,255,0.3);}
        
        .alert{padding:12px; border-radius:8px; margin-bottom:20px;}
        .alert-danger{background:#f8d7da; color:#721c24; border:1px solid #f5c6cb;}
        
        .stats-grid{display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:20px; margin-bottom:30px;}
        .stat-card{background:white; border-radius:16px; padding:24px; box-shadow:0 4px 15px rgba(0,0,0,0.1);}
        .stat-icon{width:50px; height:50px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:24px; margin-bottom:12px;}
        .stat-icon.success{background:#d4edda; color:#155724;}
        .stat-icon.warning{background:#fff3cd; color:#856404;}
        .stat-icon.info{background:#d1ecf1; color:#0c5460;}
        .stat-icon.primary{background:#cfe2ff; color:#084298;}
        .stat-value{font-size:28px; font-weight:700; margin-bottom:4px;}
        .stat-label{color:var(--muted); font-size:14px;}
        
        .card{background:white; border-radius:16px; padding:28px; box-shadow:0 4px 15px rgba(0,0,0,0.1); margin-bottom:20px;}
        .card-header{display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; padding-bottom:16px; border-bottom:2px solid #f0f0f0;}
        .card-header h3{font-size:20px; color:#333;}
        
        @@media (max-width:768px){
            .dashboard{flex-direction:column;}
            .sidebar{width:100%;}
            .stats-grid{grid-template-columns:1fr;}
        }
    </style>
}

<div class="dashboard">
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="avatar">👤</div>
            <div class="user-name">@Model.FullName</div>
            <div class="user-email">@Model.Email</div>
            <span class="user-role @Model.RoleCss">@Model.Role</span>
        </div>
        
        <ul class="menu">
            <li><a href="/profile" class="active"><span class="menu-icon">👤</span> Профиль</a></li>
            <li><a href="@Model.DashboardUrl"><span class="menu-icon">📊</span> Панель</a></li>
            <li>
                <form method="post" asp-page-handler="Logout">
                    <button type="submit"><span class="menu-icon">🚪</span> Выйти</button>
                </form>
            </li>
        </ul>
    </aside>
    
    <main class="main-content">
        <div class="container">
            <div class="header">
                <h1>Профиль</h1>
                <form method="post" asp-page-handler="Logout">
                    <button class="btn btn-logout" type="submit">Выйти</button>
                </form>
            </div>
            
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon success">✅</div>
                    <div class="stat-value">@Model.ActiveCourses</div>
                    <div class="stat-label">Активные курсы</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon warning">🏁</div>
                    <div class="stat-value">@Model.CompletedCourses</div>
                    <div class="stat-label">Завершенные курсы</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon info">📅</div>
                    <div class="stat-value">@Model.MemberSince</div>
                    <div class="stat-label">Участник с</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon primary">⏰</div>
                    <div class="stat-value">@Model.LastLogin</div>
                    <div class="stat-label">Последний вход</div>
                </div>
            </div>
            
            <div class="card">
                <div class="card-header">
                    <h3>Информация о пользователе</h3>
                </div>
                <p><strong>ID:</strong> @Model.UserId</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Имя:</strong> @Model.FirstName</p>
                <p><strong>Фамилия:</strong> @Model.LastName</p>
                <p><strong>Роль:</strong> @Model.Role</p>
            </div>
        </div>
    </main>
</div>
