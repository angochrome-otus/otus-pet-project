@page "/health-status"
@{
    ViewData["Title"] = "Health Status";
}

@section Head {
    <style>
        .wrap{max-width:900px;margin:0 auto;padding:50px 20px;}
        h1{color:white;margin-bottom:14px;}
        .card{background:var(--card-bg);border-radius:16px;padding:22px;box-shadow:0 4px 15px rgba(0,0,0,0.12);margin-bottom:16px;}
        .muted{color:var(--muted);}
        a{color:#1976D2;text-decoration:none;font-weight:600;}
        a:hover{text-decoration:underline;}
        ul{margin:10px 0 0 18px;}
    </style>
}

<div class="wrap">
    <h1>Health Status</h1>

    <div class="card">
        <p class="muted">API Gateway health:</p>
        <ul>
            <li><a href="/health/live">/health/live</a></li>
            <li><a href="/health/ready">/health/ready</a></li>
            <li><a href="/metrics">/metrics</a></li>
        </ul>
    </div>

    <div class="card">
        <p class="muted">Helpful links:</p>
        <ul>
            <li><a href="/">Home</a></li>
        </ul>
    </div>
</div>
